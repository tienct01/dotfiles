// Zed settins
//
// For information on how to configure Zed, see the Zed
// documentation: https://zed.dev/docs/configuring-zed
//
// To see all of Zed's default settings without changing your
// custom settings, run `zed: open default settings` from the
// command palette (cmd-shift-p / ctrl-shift-p)
{
  // AI
  "diff_view_style": "split",

  "edit_predictions": {
    "provider": "none"
  },
  "agent_servers": {
    "opencode": {
      "type": "registry",
      "default_mode": "plan",
    }
  },
  "disable_ai": false,
  "show_edit_predictions": false,

  // Agent AI Setup
  "agent": {
    "dock": "left",
    "default_profile": "ask",
    "default_model": {
      "effort": "high",
      "enable_thinking": true,
      "provider": "copilot_chat",
      "model": "gemini-3.1-pro-preview",
    },
    "favorite_models": [],
    "model_parameters": []
  },

  // SSH setup
  "ssh_connections": [
    {
      "host": "banner-test",
      "args": [],
      "projects": [
        {
          "paths": [
            "/var"
          ]
        },
        {
          "paths": [
            "/var/www/html"
          ]
        }
      ]
    },
    {
      "host": "banner-prod",
      "args": [],
      "projects": [
        {
          "paths": [
            "/var/www/html"
          ]
        }
      ]
    },
    {
      "host": "support-tool-prod",
      "args": [],
      "projects": [
        {
          "paths": [
            "/var/www/html/updateBannerPopupRepo.sh"
          ]
        }
      ]
    },
    {
      "host": "banner-public-prod",
      "args": [],
      "projects": [
        {
          "paths": [
            "/var/www/html"
          ]
        },
        {
          "paths": [
            "/var/www/html/banner-public-api"
          ]
        }
      ]
    }
  ],

  // UI Configuration
  "git_panel": {
    "dock": "right",
    "tree_view": true
  },

  "outline_panel": {
    "dock": "right",
  },

  "collaboration_panel": {
    "dock": "right"
  },

  "project_panel": {
    "dock": "right"
  },

  "icon_theme": {
    "mode": "dark",
    "light": "Material Icon Theme",
    "dark": "Material Icon Theme"
  },
  "theme": {
    "mode": "dark",
    "light": "Catppuccin Latte",
    "dark": "Catppuccin Macchiato"
  },

  "tabs": {
    "git_status":true,
    "show_diagnostics": "errors",
    "file_icons": true,
    "show_close_button": "always",
  },

  "indent_guides": {
    "enabled": true,
    "coloring": "indent_aware",
  },

  "diagnostics": {
    "inline": {
      "enabled": true,
    },
  },

  "ui_font_size": 16,
  "ui_font_family": "JetBrainsMono Nerd Font",
  "ui_font_weight": 400,

  // Buffer config
  "buffer_font_size": 14,
  "buffer_font_family": "JetBrainsMono Nerd Font Mono",
  "buffer_font_weight": 400,
  "buffer_line_height": "standard",

  // Terminal
  "terminal": {
    "font_size": 13,
    "line_height": "standard",
    "font_family": "JetBrainsMono Nerd Font Mono"
  },

  "cursor_blink": false,

  // Vim
  "vim_mode": true,
  "vim": {
    "toggle_relative_line_numbers": true,
    "highlight_on_yank_duration": 200,
    "use_smartcase_find": true,
    "use_regex_search": true
  },

  // Prettier format
  "formatter": "auto",
  "format_on_save": "off",
  "prettier": {
    "allowed": true
  },
}
